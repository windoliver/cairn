        },
        {
          "$ref": "#/$defs/filter_or_L2"
        },
        {
          "$ref": "#/$defs/filter_not_L2"
        }
      ]
    },
    "filter_and_L2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "and"
      ],
      "properties": {
        "and": {
          "type": "array",
          "minItems": 1,
